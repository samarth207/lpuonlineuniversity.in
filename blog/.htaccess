RewriteEngine On
RewriteBase /blog/

# If the request is not for an existing file or directory
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Rewrite clean URLs to post.php
# /blog/some-slug -> /blog/post.php?slug=some-slug
RewriteRule ^([a-z0-9-]+)/?$ post.php?slug=$1 [L,QSA]
